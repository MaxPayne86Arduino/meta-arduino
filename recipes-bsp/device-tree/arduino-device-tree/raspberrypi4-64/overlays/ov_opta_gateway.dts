/*
 * Device tree overlay for Arduino Opta Gateway ARCH1 / ARCH2
 *
 * Arduino Oct 2024
 */

/dts-v1/;
/plugin/;

#include <dt-bindings/pinctrl/bcm2835.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>

/ {
	compatible = "brcm,bcm2835";

	/* SPI */

	fragment@0 {
		target = <&spidev0>;
		__dormant__ {
			status = "disabled";
		};
	};

	fragment@1 {
		target = <&spidev1>;
		__dormant__ {
			status = "disabled";
		};
	};

	fragment@2 {
		target-path = "spi1/spidev@0";
		__dormant__ {
			status = "disabled";
		};
	};

	fragment@3 {
		target-path = "spi1/spidev@1";
		__dormant__ {
			status = "disabled";
		};
	};

	fragment@4 {
		target-path = "spi1/spidev@2";
		__dormant__ {
			status = "disabled";
		};
	};

	fragment@5 {
		target-path = "spi2/spidev@0";
		__dormant__ {
			status = "disabled";
		};
	};

	fragment@6 {
		target-path = "spi2/spidev@1";
		__dormant__ {
			status = "disabled";
		};
	};

	fragment@7 {
		target-path = "spi2/spidev@2";
		__dormant__ {
			status = "disabled";
		};
	};

	fragment@8 {
		target = <&spi6_cs_pins>;
		__overlay__ {
			brcm,pins = <18 17 16>;
			brcm,function = <1>; /* output */
		};
	};

	fragment@9 {
		target = <&spi6>;
		__overlay__ {
			/* needed to avoid dtc warning */
			#address-cells = <1>;
			#size-cells = <0>;

			pinctrl-names = "default";
			pinctrl-0 = <&spi6_pins &spi6_cs_pins>;
			cs-gpios = <&gpio 18 1>, <&gpio 17 1>, <&gpio 16 1>;
			status = "okay";

			/* To ARCH1 */
			/* @TODO: bind devices on ARCH1 */
			spidev6_0: spidev@0 {
				compatible = "spidev";
				reg = <0>;      /* CE0 */
				#address-cells = <1>;
				#size-cells = <0>;
				spi-max-frequency = <125000000>;
				status = "okay";
			};

			/* To ARCH1 */
			/* @TODO: bind devices on ARCH1 */
			spidev6_1: spidev@1 {
				compatible = "spidev";
				reg = <1>;      /* CE1 */
				#address-cells = <1>;
				#size-cells = <0>;
				spi-max-frequency = <125000000>;
				status = "okay";
			};

			/* Sd Card */
			/* @TODO: compatible mmc-spi */
			spidev6_3: spidev@2 {
				compatible = "spidev";
				reg = <2>;      /* CS */
				#address-cells = <1>;
				#size-cells = <0>;
				spi-max-frequency = <125000000>;
				status = "okay";
			};
		};
	};

	/* I2C */

	/* ID_SD / ID_SC
	@TODO: fix i2c node name, bind following devices
	- EEPROM
	- GPIOEXP1
	- GPIOEXP2
	- RTC
	*/
	fragment@10 {
		target = <&i2c_csi_dsi>;
		__overlay__ {
			#address-cells = <1>;
			#size-cells = <0>;
			status = "okay";

			/* U5 RTC */
			// INTA -> GLOBAL_EN
			// INTB -> gpioexp_1 P00A
			pcf8523: pcf8523@68 {
				compatible = "nxp,pcf8523";
				reg = <0x68>;
			};

			/* U2_1 GPIO EXP */
			gpioexp_1: gpio@21 {
				compatible = "nxp,pca9535";
				pinctrl-names = "default";
				pinctrl-0 = <&pinctrl_gpioexp_1>;
				reg = <0x20>;
				gpio-controller;
				#gpio-cells = <2>;
				interrupt-controller;
				#interrupt-cells = <2>;
				interrupt-parent = <&gpio>;
				interrupts = <24 IRQ_TYPE_LEVEL_LOW>;
			};

			/* U2_2 GPIO EXP */
			gpioexp_1: gpio@20 {
				compatible = "nxp,pca9535";
				pinctrl-names = "default";
				pinctrl-0 = <&pinctrl_gpioexp_1>;
				reg = <0x20>;
				gpio-controller;
				#gpio-cells = <2>;
				interrupt-controller;
				#interrupt-cells = <2>;
				interrupt-parent = <&gpio>;
				interrupts = <25 IRQ_TYPE_LEVEL_LOW>;
			};

			/*  U4 EEPROM 0x50 */
			/* WP is held to GND */
			eeprom@50 {
				compatible = "atmel,24c02";
				reg = <0x50>;
				pagesize = <16>;
			};
		};
	};

	/* PINMUX */
	fragment@11 {
		target = <&gpio>;
		__overlay__ {
			pinctrl_gpioexp_1: gpioexp_1grp {
				brcm,pins = <24>;
				brcm,function = <BCM2835_FSEL_GPIO_OUT>;
			};

			pinctrl_gpioexp_2: gpioexp_2grp {
				brcm,pins = <25>;
				brcm,function = <BCM2835_FSEL_GPIO_OUT>;
			};
		};
	};

	/* @TODO: next nodes */
};
