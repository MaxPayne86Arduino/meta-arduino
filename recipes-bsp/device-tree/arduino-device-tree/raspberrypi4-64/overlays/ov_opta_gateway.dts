/*
 * Device tree overlay for Arduino Opta Gateway ARCH1 / ARCH2
 *
 * Arduino Oct 2024
 */

/dts-v1/;
/plugin/;

#include <dt-bindings/pinctrl/bcm2835.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>

/ {
	compatible = "brcm,bcm2835";

	/* SPI */

	fragment@0 {
		target = <&spi1>;
		__overlay__ {
			/* needed to avoid dtc warning */
			#address-cells = <1>;
			#size-cells = <0>;

			pinctrl-names = "default";
			pinctrl-0 = <&spi1_gpio16>;
			status = "okay";

			/* To ARCH1 */
			/* @TODO: bind devices on ARCH1 */
			spidev1_0: spidev@0 {
				compatible = "spidev";
				reg = <0>;      /* CE0 */
				#address-cells = <1>;
				#size-cells = <0>;
				spi-max-frequency = <125000000>;
				status = "okay";
			};

			/* To ARCH1 */
			/* @TODO: bind devices on ARCH1 */
			spidev1_1: spidev@1 {
				compatible = "spidev";
				reg = <1>;      /* CE1 */
				#address-cells = <1>;
				#size-cells = <0>;
				spi-max-frequency = <125000000>;
				status = "okay";
			};

			/* Sd Card */
			mmc_slot: mmcslot@2 {
				compatible = "mmc-spi-slot";
				voltage-ranges = <3300 3300>;
				reg = <2>;      /* CS */
				#address-cells = <1>;
				#size-cells = <0>;
				spi-max-frequency = <5000000>;
				status = "okay";
			};
		};
	};

	/* I2C */

	/* ID_SD / ID_SC
	// See i2c0-overlay.dts
	// You can just load dtoverlay=i2c0
	@TODO: fix i2c node name, bind following devices
	- EEPROM
	- GPIOEXP1
	- GPIOEXP2
	- RTC
	*/
	fragment@1 {
		target = <&i2c0mux>;
		__overlay__ {
			status = "disabled";
		};
	};

	fragment@2 {
		target = <&i2c0if>;
		__overlay__ {
			pinctrl-names = "default";
			pinctrl-0 = <&i2c0_pins>;
			status = "okay";

			/* U5 RTC */
			// INTA -> GLOBAL_EN
			// INTB -> gpioexp_1 P00A
			pcf8523: pcf8523@68 {
				compatible = "nxp,pcf8523";
				reg = <0x68>;
			};

			/* U2_1 GPIO EXP */
			// See pca953x-overlay.dts
			gpioexp_1: gpio@21 {
				compatible = "nxp,pca9535";
				//pinctrl-names = "default";
				//pinctrl-0 = <&pinctrl_gpioexp_1>;
				reg = <0x21>;
				gpio-controller;
				#gpio-cells = <2>;
				//interrupt-controller;
				//#interrupt-cells = <2>;
				//interrupt-parent = <&gpio>;
				//interrupts = <24 IRQ_TYPE_LEVEL_LOW>;
			};

			/* U2_2 GPIO EXP */
			// // See pca953x-overlay.dts
			gpioexp_2: gpio@20 {
				compatible = "nxp,pca9535";
				//pinctrl-names = "default";
				//pinctrl-0 = <&pinctrl_gpioexp_2>;
				reg = <0x20>;
				gpio-controller;
				#gpio-cells = <2>;
				//interrupt-controller;
				//#interrupt-cells = <2>;
				//interrupt-parent = <&gpio>;
				//interrupts = <25 IRQ_TYPE_LEVEL_LOW>;
			};

			/*  U4 EEPROM 0x50 */
			/* WP is held to GND */
			eeprom@50 {
				compatible = "atmel,24c02";
				reg = <0x50>;
				pagesize = <16>;
			};
		};
	};

	/* USB */
	// See dwc2-overlay.dts
	// You can just load dtoverlay=dwc2
	fragment@3 {
		target = <&usb>;
		#address-cells = <1>;
		#size-cells = <1>;
		dwc2_usb: __overlay__ {
			compatible = "brcm,bcm2835-usb";
			dr_mode = "otg";
			g-np-tx-fifo-size = <32>;
			g-rx-fifo-size = <558>;
			g-tx-fifo-size = <512 512 512 512 512 256 256>;
			status = "okay";
		};
	};


	/* PINMUX */
	fragment@4 {
		target = <&gpio>;
		__overlay__ {
			pinctrl_gpioexp_1: gpioexp_1grp {
				brcm,pins = <24>;
				brcm,function = <BCM2835_FSEL_GPIO_OUT>;
			};

			pinctrl_gpioexp_2: gpioexp_2grp {
				brcm,pins = <25>;
				brcm,function = <BCM2835_FSEL_GPIO_OUT>;
			};
		};
	};

	/* @TODO: next nodes */
};
