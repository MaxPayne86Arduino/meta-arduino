bootlimit=3
devnum=0
devtype=mmc

# Amended variables, see u-boot default env
fdt_addr=0x2eff2a00
fdt_file=/boot2/devicetree/bcm2711-rpi-cm4-optagateway.dtb
kernel_addr_r=0x00080000

# Overlay variables
overlays="ov_opta_gateway"
ovlload=ext4load
ovltype=mmc
ovlpart=2
ovldev=0
ovlpath=/boot2/devicetree
fdtovaddr=0x2f102c2d # Addr fdt_addr + size fdt_file + 64KB margin

bootcmd_args=setenv bootargs coherent_pool=1M 8250.nr_uarts=1 console=tty1 console=ttyS0,115200 root=/dev/mmcblk0p2 rootfstype=ext4 rootwait rw
bootcmd_load_k=fatload ${devtype} ${devnum}:1 ${kernel_addr_r} Image
bootcmd_load_fdt=ext4load ${devtype} ${devnum}:2 ${fdt_addr} ${fdt_file}
bootcmd_ovl=fdt addr ${fdt_addr}; fdt resize 0x${filesize}; \
             for ov in ${overlays}; do \
               echo overlaying ${ov}...; \
               ${ovlload} ${ovltype} ${ovldev}:${ovlpart} ${fdtovaddr} ${ovlpath}/${ov}.dtbo && \
               fdt apply ${fdtovaddr}; \
             done
bootcmd_run=booti ${kernel_addr_r} - ${fdt_addr}
#bootcmd=run bootcmd_args; run bootcmd_load_k; run bootcmd_load_fdt; run bootcmd_ovl; run bootcmd_run
bootcmd=run bootcmd_args; run bootcmd_load_k; run bootcmd_load_fdt; run bootcmd_run
