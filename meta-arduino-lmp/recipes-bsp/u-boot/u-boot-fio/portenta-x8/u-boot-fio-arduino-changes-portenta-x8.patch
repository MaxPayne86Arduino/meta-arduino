+static unsigned char ext_usb_hub_cfg_1[] = {
+	0x11,	//data size
+	0x24,	//VID LSB
+	0x04,	//VID_MSB
+	0x14,	//PID LSB
+	0x25,	//PID MSB
+	0x00,	//DID LSB
