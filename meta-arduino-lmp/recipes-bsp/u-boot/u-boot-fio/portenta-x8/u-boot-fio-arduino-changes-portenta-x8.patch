+static void anx7625_msg_dump(const uint8_t *msg_buf, uint8_t msg_size)
+{
+	debug("%s:", __func__);
+	for (int i = 0; i < msg_size; i++) {
+		if (i == 0)
+	                debug(" (%d)", msg_buf[i]);
+		else if (i == 1)
+	                debug(" [0x%02x/%s]", msg_buf[i], anx7625_msg_type_str(msg_buf[i]));
+		else if (i == msg_size - 1)
+	                debug(" {0x%02x}", msg_buf[i]);
+		else
+	                debug(" 0x%02x", msg_buf[i]);
+	}
+	debug("\n");
