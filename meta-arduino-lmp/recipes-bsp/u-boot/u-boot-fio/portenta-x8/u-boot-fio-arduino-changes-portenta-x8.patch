+static uint8_t anx7625_msg_calc_checksum(uint8_t *msg_buf, uint8_t msg_size)
+{
+	uint8_t checksum = 0;
+
+	for (int i = 0; i < msg_size; i++)
+		checksum += msg_buf[i];
+
+	return (uint8_t)(0 - checksum);
+}
