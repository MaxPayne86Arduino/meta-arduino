#!/bin/sh

# Use NetworkManager's connectivity check
# Returns: none, portal, limited, full, unknown
connectivity=$(nmcli -t -f CONNECTIVITY networking connectivity check 2>/dev/null)

# Consider "full" or "portal" as connected (portal means captive portal detected but connection exists)
case "$connectivity" in
    full|portal)
        echo default-on > /sys/class/leds/ledG/trigger
        ;;
    *)
        echo none > /sys/class/leds/ledG/trigger
        ;;
esac
