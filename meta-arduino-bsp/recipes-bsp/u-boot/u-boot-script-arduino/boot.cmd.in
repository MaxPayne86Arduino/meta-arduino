# Import custom env file
setenv bootenv uEnv.txt
setenv bootdir /boot
setenv loadbootenv load mmc ${mmcdev}:${mmcpart} ${loadaddr} ${bootdir}/${bootenv}
setenv importbootenv echo Importing environment from mmc ...; env import -t -r $loadaddr $filesize
run loadbootenv
run importbootenv

# Set environment variables
setenv fdt_addr 0x83000000
setenv image ${bootdir}/Image
setenv loadaddr 0x80400000
setenv loadfdt echo fdt_file=${fdt_file}; load mmc ${mmcdev}:${mmcpart} ${fdt_addr} ${bootdir}/devicetree/${fdt_file}

setenv devtype mmc
setenv ovlload ext4load
setenv ovltype mmc
setenv ovlpart ${mmcpart}
setenv ovldev ${mmcdev}
setenv ovlpath ${bootdir}/devicetree
setenv fdtovaddr 0x83600000
setenv remove_nodes 'for node in ${ovlrm}; do \
                        echo Removing node ${node}; \
                        fdt rm ${node}; \
                      done'
setenv bootcmd_ovl 'fdt addr ${fdt_addr}; \
                    run remove_nodes; \
                    fdt resize 0x${filesize}; \
                    for ov in ${overlays}; do \
                      echo overlaying ${ov}...; \
                      ${ovlload} ${ovltype} ${ovldev}:${ovlpart} ${fdtovaddr} ${ovlpath}/${ov}.dtbo && \
                      fdt apply ${fdtovaddr}; \
                    done'

# Set boot arguments
run mmcargs

# Load the kernel image and device tree blob
echo "Using kernel image ${image}"
run loadimage
echo "Using root devicetree ${fdt_file}"
run loadfdt

# Apply overlays
run bootcmd_ovl

# Bootargs
setenv console ttyLP2,115200 earlycon
run mfgtool_args
#setenv bootargs console=${console},${baudrate} rdinit=/linuxrc clk_ignore_unused # Init: linuxrc
setenv bootargs console=${console},${baudrate} rdinit=/sbin/init clk_ignore_unused # Init: systemd

# Boot the kernel
booti ${loadaddr} - ${fdt_addr}
