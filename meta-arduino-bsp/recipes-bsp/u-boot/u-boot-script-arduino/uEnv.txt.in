# Define root devicetree file available in /boot/devicetree
fdt_file=arduino_portenta-x9.dtb

# Define devicetree nodes to be removed (optional)
# Example: ovlrm='/soc@0/bus@32c00000/usb@32e40000/port/endpoint'
ovlrm=''

# Define devicetree overlay list (optional)
# Example: overlays='overlay1 overlay2 overlay3'
overlays=''

# Init: linuxrc
#rdinit=/linuxrc

# Init: systemd
rdinit=/sbin/init

mmcargs=setenv bootargs console=${console} root=${mmcroot} rdinit=${rdinit} clk_ignore_unused rootwait rw ${cma_size} cma_name=linux,cma
