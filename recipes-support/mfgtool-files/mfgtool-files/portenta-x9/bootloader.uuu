uuu_version 1.4.149

SDPS: boot -f imx-boot-mfgtool

FB: ucmd setenv fastboot_dev mmc
FB: ucmd setenv mmcdev 0
FB: ucmd mmc dev ${mmcdev} 1; mmc erase 0 0x3C00
FB: flash bootloader ../imx-boot-portenta-x9
FB: flash bootloader2 ../u-boot-portenta-x9.itb
FB: flash bootloader_s ../imx-boot-portenta-x9
FB: flash bootloader2_s ../u-boot-portenta-x9.itb
FB: ucmd mmc partconf 0 0 1 0
FB: done
